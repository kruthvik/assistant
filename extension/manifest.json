{
    "manifest_version": 2,
    "name": "Screenshot Analyzer",
    "version": "1.3",
    "description": "Capture full page or snip a region, then analyze with Gemini.",
    "browser_specific_settings": {
        "gecko": {
            "id": "screenshot-analyzer@extension"
        }
    },
    "permissions": [
        "activeTab",
        "tabs",
        "storage",
        "<all_urls>"
    ],
    "browser_action": {
        "default_title": "Screenshot Analyzer"
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "commands": {
        "capture-full": {
            "suggested_key": {
                "default": "Alt+Shift+A"
            },
            "description": "Capture full visible tab and analyze"
        },
        "capture-snip": {
            "suggested_key": {
                "default": "Alt+Shift+X"
            },
            "description": "Snip a rectangular region and analyze"
        }
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    }
}
